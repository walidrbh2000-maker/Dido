_$ReservationModelImpl _$$ReservationModelImplFromJson(
        Map<String, dynamic> json) =>
    _$ReservationModelImpl(
      id: (json['id'] as num).toInt(),
      userId: (json['userId'] as num).toInt(),
      volId: (json['volId'] as num).toInt(),
      hotelId: (json['hotelId'] as num?)?.toInt(),
      dateDebut: json['dateDebut'] as String,
      dateFin: json['dateFin'] as String,
      nombrePersonnes: (json['nombrePersonnes'] as num).toInt(),
      prixTotal: (json['prixTotal'] as num).toDouble(),
